---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Fletes Industriales Nuevo León">

  <section id="inicio" class="relative bg-gray-900 min-h-[65vh] flex items-center">
    <div class="absolute inset-0 z-0 overflow-hidden">
      <video id="hero-video" src="/videos/hero-o.mp4" poster="/hero-mafra.jpg" autoplay muted loop playsinline class="w-full h-full object-cover opacity-45 transform scale-105"></video>
      <div class="absolute inset-0 bg-gradient-to-r from-secondary/90 via-secondary/60 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-12 flex flex-col items-center text-center text-white">
      <h1 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight lg:whitespace-nowrap">Fletes Industriales<br class="hidden [@media(min-width:640px)_and_(max-width:747px)]:inline" /> Nuevo León</h1>
      <p class="mt-6 text-lg text-gray-200 max-w-2xl">¿Necesitas transportar maquinaria o mercancía con urgencia?</p>
      <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm">
        <div class="flex items-center gap-2"><i class="ph ph-clock-countdown text-primary text-xl"></i> Monitoreo Real 24/7</div>
        <div class="flex items-center gap-2"><i class="ph ph-shield-check text-primary text-xl"></i> Unidades Certificadas</div>
      </div>
      <a href="tel:+528129115812" class="mt-8 inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold py-3 px-8 rounded text-sm transition-colors shadow-sm">
        <i class="ph ph-phone-call text-lg"></i>
        Cotizar Ahora
      </a>
    </div>
  </section>

  <section id="flota" class="py-20 bg-gray-50 border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-primary text-xs font-bold uppercase tracking-widest">Equipamiento Superior</span>
        <h2 class="text-3xl font-extrabold text-secondary tracking-tight border-none p-0 mt-2">Soluciones de Carga a tu Medida</h2>
        <p class="text-text-muted mt-3">Realizamos fletes especializados en todo Nuevo León con disponibilidad 24/7 dependiendo de tu unidad, ruta y carga.</p>
      </div>

      <div class="swiper flotaSwiper pb-12">
        <div class="swiper-wrapper">
          <div class="swiper-slide bg-white rounded border border-gray-100 overflow-hidden shadow-sm flex flex-col h-full">
            <div class="h-48 bg-gray-100 relative">
              <img src="/images/caja_seca.webp" alt="Caja Seca de 53 Pies" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-grow flex flex-col">
              <h3 class="text-lg font-bold text-secondary mt-0">Caja Seca de 53 Pies</h3>
              <ul class="text-xs text-secondary space-y-2 mt-4 pt-4 border-t border-gray-100">
                <li><strong>Capacidad:</strong> Hasta 25-28 Toneladas</li>
                <li><strong>Seguridad:</strong> Rastreo GPS satelital activo continuo</li>
              </ul>
              <div class="flex-grow"></div>
              <a href="#cotizar" class="mt-4 inline-flex items-center justify-center w-full bg-primary hover:bg-primary/90 text-white text-sm font-semibold py-2.5 rounded transition-colors">Solicitar</a>
            </div>
          </div>
          <div class="swiper-slide bg-white rounded border border-gray-100 overflow-hidden shadow-sm flex flex-col h-full">
            <div class="h-48 bg-gray-100 relative">
              <img src="/images/rabones_de_caja.webp" alt="Rabones de Caja 26 Pies" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-grow flex flex-col">
              <h3 class="text-lg font-bold text-secondary mt-0">Rabones de Caja (26')</h3>
              <ul class="text-xs text-secondary space-y-2 mt-4 pt-4 border-t border-gray-100">
                <li><strong>Capacidad:</strong> Hasta 8-10 Toneladas</li>
                <li><strong>Ventaja:</strong> Maniobrabilidad en zonas de difícil acceso</li>
              </ul>
              <div class="flex-grow"></div>
              <a href="#cotizar" class="mt-4 inline-flex items-center justify-center w-full bg-primary hover:bg-primary/90 text-white text-sm font-semibold py-2.5 rounded transition-colors">Solicitar</a>
            </div>
          </div>
          <div class="swiper-slide bg-white rounded border border-gray-100 overflow-hidden shadow-sm flex flex-col h-full">
            <div class="h-48 bg-gray-100 relative">
              <img src="/images/plataforma48.webp" alt="Plataforma de 48 y 53 Pies" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-grow flex flex-col">
              <h3 class="text-lg font-bold text-secondary mt-0">Plataforma de 48 y 53 Pies</h3>
              <ul class="text-xs text-secondary space-y-2 mt-4 pt-4 border-t border-gray-100">
                <li><strong>Capacidad:</strong> Configuraciones full y sencillo</li>
                <li><strong>Amarre:</strong> Sistemas de sujeción certificados de alta resistencia</li>
              </ul>
              <div class="flex-grow"></div>
              <a href="#cotizar" class="mt-4 inline-flex items-center justify-center w-full bg-primary hover:bg-primary/90 text-white text-sm font-semibold py-2.5 rounded transition-colors">Solicitar</a>
            </div>
          </div>
          <div class="swiper-slide bg-white rounded border border-gray-100 overflow-hidden shadow-sm flex flex-col h-full">
            <div class="h-48 bg-gray-100 relative">
              <img src="/images/caja_refrigerada.webp" alt="Caja Refrigerada 53 Pies" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-grow flex flex-col">
              <h3 class="text-lg font-bold text-secondary mt-0">Refrigeradas 53'</h3>
              <ul class="text-xs text-secondary space-y-2 mt-4 pt-4 border-t border-gray-100">
                <li><strong>Capacidad:</strong> Hasta 25-28 Toneladas</li>
                <li><strong>Control:</strong> Monitoreo continuo de temperatura</li>
              </ul>
              <div class="flex-grow"></div>
              <a href="#cotizar" class="mt-4 inline-flex items-center justify-center w-full bg-primary hover:bg-primary/90 text-white text-sm font-semibold py-2.5 rounded transition-colors">Solicitar</a>
            </div>
          </div>
          <div class="swiper-slide bg-white rounded border border-gray-100 overflow-hidden shadow-sm flex flex-col h-full">
            <div class="h-48 bg-gray-100 relative">
              <img src="/images/unidades3_5_cajacerrada.webp" alt="Unidad 3.5 Toneladas Plataforma y Caja Cerrada" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-grow flex flex-col">
              <h3 class="text-lg font-bold text-secondary mt-0">Unidades 3.5 Plataforma y Caja Cerrada</h3>
              <ul class="text-xs text-secondary space-y-2 mt-4 pt-4 border-t border-gray-100">
                <li><strong>Capacidad:</strong> Hasta 3.5 Toneladas</li>
                <li><strong>Ventaja:</strong> Disponibilidad inmediata y bajo costo por viaje</li>
              </ul>
              <div class="flex-grow"></div>
              <a href="#cotizar" class="mt-4 inline-flex items-center justify-center w-full bg-primary hover:bg-primary/90 text-white text-sm font-semibold py-2.5 rounded transition-colors">Solicitar</a>
            </div>
          </div>
          <div class="swiper-slide bg-white rounded border border-gray-100 overflow-hidden shadow-sm flex flex-col h-full">
            <div class="h-48 bg-gray-100 relative">
              <img src="/images/ltl.webp" alt="Carga Consolidada LTL" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-grow flex flex-col">
              <h3 class="text-lg font-bold text-secondary mt-0">LTL (Consolidados)</h3>
              <ul class="text-xs text-secondary space-y-2 mt-4 pt-4 border-t border-gray-100">
                <li><strong>Capacidad:</strong> Espacio según volumen contratado</li>
                <li><strong>Eficiencia:</strong> Reduce costos logísticos unitarios por ruta</li>
              </ul>
              <div class="flex-grow"></div>
              <a href="#cotizar" class="mt-4 inline-flex items-center justify-center w-full bg-primary hover:bg-primary/90 text-white text-sm font-semibold py-2.5 rounded transition-colors">Solicitar</a>
            </div>
          </div>
        </div>
        <div class="swiper-pagination mt-4"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
      </div>
    </div>
  </section>

  <section id="servicios-brindados" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl font-extrabold text-secondary tracking-tight border-none p-0">Servicios que te brindamos</h2>
        <p class="text-text-muted mt-3">Nos llamas, confirmamos disponibilidad y asignamos la unidad. Movemos tu carga con cobro por viaje, sin contratos ni compromisos. Ideal para operaciones regulares, urgencias y servicios dedicados.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gray-50 p-8 rounded border border-gray-100 flex flex-col">
          <div class="bg-primary/10 text-primary w-12 h-12 rounded flex items-center justify-center text-2xl mb-6">
            <i class="ph ph-lightning"></i>
          </div>
          <h3 class="text-lg font-bold text-secondary mt-0">Hotshot Trucking (Urgencias)</h3>
          <p class="text-text-muted text-sm mt-2">Atendemos envíos de última hora para industrias como manufactura y maquiladoras.</p>
        </div>

        <div class="bg-gray-50 p-8 rounded border border-gray-100 flex flex-col">
          <div class="bg-primary/10 text-primary w-12 h-12 rounded flex items-center justify-center text-2xl mb-6">
            <i class="ph ph-truck"></i>
          </div>
          <h3 class="text-lg font-bold text-secondary mt-0">Flota Propia</h3>
          <p class="text-text-muted text-sm mt-2">Asignamos unidades dedicadas con disponibilidad garantizada.</p>
        </div>

        <div class="bg-gray-50 p-8 rounded border border-gray-100 flex flex-col">
          <div class="bg-primary/10 text-primary w-12 h-12 rounded flex items-center justify-center text-2xl mb-6">
            <i class="ph ph-headset"></i>
          </div>
          <h3 class="text-lg font-bold text-secondary mt-0">Monitoreo y Soporte 24/7</h3>
          <p class="text-text-muted text-sm mt-2">Rastreo y atención para asegurar que tu carga llegue a tiempo.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="servicios" class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/bento-ftl.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-[#1a1a1a]/60"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <span class="text-primary text-xs font-bold uppercase tracking-widest">Mafra Logistics</span>
        <h2 class="text-3xl font-extrabold text-white mt-2 tracking-tight border-none p-0">¿Por qué debes elegirnos?</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-[#1a1a1a] border border-text-muted/40 rounded-lg p-8 shadow-lg">
          <h3 class="text-xl font-bold text-white mt-0">Esquemas de Renta Flexibles</h3>
          <p class="text-white text-sm mt-4 leading-relaxed">Si tu operación requiere 2 o más viajes al día, te ofrecemos renta por jornada (8, 10 o 12 horas) en lugar de pagar de forma individual por cada servicio de fletes.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-2 text-sm text-white">
              <i class="ph ph-check text-primary text-base mt-0.5"></i>
              <span>Tarifa menor a mayor plazo: día, semana o mes.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white">
              <i class="ph ph-check text-primary text-base mt-0.5"></i>
              <span>Descuentos por volumen de unidades en tus fletes de carga.</span>
            </li>
          </ul>
        </div>

        <div class="bg-[#1a1a1a] border border-text-muted/40 rounded-lg p-8 shadow-lg">
          <h3 class="text-xl font-bold text-white mt-0">Proyectos de Ahorro a la Medida</h3>
          <p class="text-white text-sm mt-4 leading-relaxed">Analizamos tu operación y diseñamos un esquema logístico que reduce directamente tu costo por servicio.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-2 text-sm text-white">
              <i class="ph ph-check text-primary text-base mt-0.5"></i>
              <span>Enfocado en tus metas de ahorro anual.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white">
              <i class="ph ph-check text-primary text-base mt-0.5"></i>
              <span>Somos socios de proyecto, no solo proveedores.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="cobertura" class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <span class="text-primary text-xs font-bold uppercase tracking-widest">Mafra Logistics</span>
        <h2 class="text-3xl font-extrabold text-secondary mt-2 tracking-tight border-none p-0">Cobertura Local y Nacional</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col justify-start">
          <p class="text-text-muted leading-relaxed">Contamos con bases operativas en Nuevo León, por lo que garantizamos tiempos de respuesta mínimos y disponibilidad inmediata de equipo en las principales zonas industriales del estado.</p>
          <p class="text-text-muted leading-relaxed mt-4">Desarrollamos nuevas rutas por petición de nuestros clientes.</p>
          <p class="text-text-muted leading-relaxed mt-4">Abrimos rutas en México, desde Baja California hasta Tamaulipas, el Bajío y el centro de México.</p>
        </div>

        <div class="rounded-lg overflow-hidden shadow-lg border border-gray-100">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3856245.179822836!2d-99.81416939999998!3d25.4809102!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x86629584a2a5b05d%3A0x701df442c36cbbc6!2sNuevo%20Le%C3%B3n!5e1!3m2!1ses!2smx!4v1783646753408!5m2!1ses!2smx" width="100%" height="100%" style="border:0; min-height: 320px;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>
      </div>
    </div>
  </section>

  <section id="industrias" class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <span class="text-primary text-xs font-bold uppercase tracking-widest">Mafra Logistics</span>
        <h2 class="text-3xl font-extrabold text-secondary mt-2 tracking-tight border-none p-0">Industrias que han confiado<br class="hidden max-[747px]:inline" /> en nosotros</h2>
        <p class="text-text-muted mt-3">Entendemos la precisión operativa, las normativas y la urgencia que exigen los sectores clave de la región:</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6">
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden shadow-sm">
          <img src="/images/manufacturera.webp" alt="Industria Manufacturera" class="w-full h-32 object-cover" loading="lazy" />
          <div class="p-4 text-center">
            <span class="text-secondary font-bold text-sm">Manufacturera</span>
          </div>
        </div>
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden shadow-sm">
          <img src="/images/maquiladora.webp" alt="Industria Maquiladora" class="w-full h-32 object-cover" loading="lazy" />
          <div class="p-4 text-center">
            <span class="text-secondary font-bold text-sm">Maquiladora</span>
          </div>
        </div>
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden shadow-sm">
          <img src="/images/automotriz.webp" alt="Industria Automotriz" class="w-full h-32 object-cover" loading="lazy" />
          <div class="p-4 text-center">
            <span class="text-secondary font-bold text-sm">Automotriz</span>
          </div>
        </div>
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden shadow-sm">
          <img src="/images/construccion.webp" alt="Industria de la Construcción" class="w-full h-32 object-cover" loading="lazy" />
          <div class="p-4 text-center">
            <span class="text-secondary font-bold text-sm">Construcción</span>
          </div>
        </div>
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden shadow-sm">
          <img src="/images/siderurgia.webp" alt="Industria Siderúrgica" class="w-full h-32 object-cover" loading="lazy" />
          <div class="p-4 text-center">
            <span class="text-secondary font-bold text-sm">Siderúrgica</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="clientes" class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-primary text-xs font-bold uppercase tracking-widest">Mafra Logistics</span>
        <h2 class="text-3xl font-extrabold text-secondary mt-2 tracking-tight border-none p-0">Nuestro Portafolio de Clientes</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-white border border-gray-100 rounded-lg p-8 shadow-sm flex items-center justify-center min-h-[120px]">
          <img src="/images/ast.webp" alt="AST — Advanced Steel Technology" class="max-h-14 w-auto max-w-full object-contain" loading="lazy" />
        </div>
        <div class="bg-white border border-gray-100 rounded-lg p-8 shadow-sm flex items-center justify-center min-h-[120px]">
          <img src="/images/avery.webp" alt="Avery Dennison" class="max-h-20 w-auto max-w-full object-contain" loading="lazy" />
        </div>
        <div class="bg-white border border-gray-100 rounded-lg p-8 shadow-sm flex items-center justify-center min-h-[120px]">
          <!-- El SVG original es blanco; brightness-0 + opacity lo vuelve gris oscuro sobre fondo claro -->
          <img src="/images/ALP2022.svg" alt="A.L.P. — Lighting Component Specialists" class="h-10 w-auto max-w-full object-contain brightness-0 opacity-70" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="nosotros" class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-secondary tracking-tight border-none p-0">Sobre Nosotros</h2>
      <p class="text-text-muted leading-relaxed mt-6">En <strong class="text-secondary">Mafra Logistics</strong> somos un equipo joven, enérgico e incansablemente preparado, impulsado por una pasión colectiva por la excelencia. Combinamos a la perfección el vigor con la experiencia técnica del sector para ofrecer una experiencia logística innovadora, ágil y confiable.</p>
      <p class="text-text-muted leading-relaxed mt-4">Respaldados por una infraestructura de flota moderna y una sólida red de socios estratégicos. Somos tu fuerza dinámica de transporte con cobertura local y nacional.</p>
    </div>
  </section>

  <section id="cotizar" class="py-20 bg-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <div>
          <h2 class="text-3xl font-extrabold text-white tracking-tight border-none p-0">Envía tu Cotización</h2>
          <p class="text-white/90 mt-4 leading-relaxed">Le damos prioridad exclusiva a tu cuenta corporativa. Recibe respuesta inmediata de nuestro equipo de despacho.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-2 text-sm text-white">
              <i class="ph ph-check-circle text-white text-base mt-0.5"></i>
              <span>Respuesta en menos de 15 minutos.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white">
              <i class="ph ph-check-circle text-white text-base mt-0.5"></i>
              <span>Flota propia disponible.</span>
            </li>
          </ul>

          <div class="bg-white p-8 rounded shadow-xl mt-10">
            <form id="contact-form" class="space-y-4">
              <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <div>
                <label for="cot-nombre" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Nombre</label>
                <input id="cot-nombre" name="nombre" type="text" placeholder="Tu nombre completo" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-primary" required />
              </div>
              <div>
                <label for="cot-empresa" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Empresa</label>
                <input id="cot-empresa" name="empresa" type="text" placeholder="Nombre de tu empresa" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-primary" required />
              </div>
              <div>
                <label for="cot-correo" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Correo</label>
                <input id="cot-correo" name="correo" type="email" placeholder="correo@empresa.com" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-primary" required />
              </div>
              <div>
                <label for="cot-telefono" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Teléfono</label>
                <input id="cot-telefono" name="telefono" type="tel" placeholder="81 0000 0000" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-primary" required />
              </div>
              <div>
                <label for="cot-unidad" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Tipo de Unidad Requerida</label>
                <select id="cot-unidad" name="unidad" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-primary bg-white" required>
                  <option>Caja Seca de 53'</option>
                  <option>Rabones de Caja (26')</option>
                  <option>Plataforma de 48 y 53 pies</option>
                  <option>Refrigeradas 53'</option>
                  <option>Unidades 3.5 Plataforma y Caja Cerrada</option>
                  <option>LTL (Consolidados)</option>
                </select>
              </div>
              <div>
                <label for="cot-ruta" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Ruta (Origen/Destino)</label>
                <input id="cot-ruta" name="ruta" type="text" placeholder="Ej. Monterrey → Saltillo" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-primary" required />
              </div>
              <button id="contact-submit" type="submit" class="w-full bg-primary hover:bg-primary/90 disabled:bg-text-muted disabled:cursor-not-allowed text-white font-bold py-3 px-4 rounded text-sm transition-colors mt-2 shadow-sm">Cotizar</button>
              <p id="contact-status" class="hidden text-sm font-semibold" role="status" aria-live="polite"></p>
            </form>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-extrabold text-white tracking-tight border-none p-0">¿Urgencia de Última Hora?</h2>
          <p class="text-white/90 mt-4 leading-relaxed">No dejes que se detenga tu cadena de suministro. Te asignamos una unidad de inmediato con control y monitoreo continuo.</p>
          <a href="tel:+528129115812" class="mt-8 inline-flex items-center gap-2 bg-white hover:bg-gray-100 text-primary font-bold py-3 px-8 rounded text-sm transition-colors shadow-sm">
            <i class="ph ph-phone-call text-lg"></i>
            Llamada Directa
          </a>
        </div>

      </div>
    </div>
  </section>

  <script>
    const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null;
    if (heroVideo) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        heroVideo.pause();
      } else {
        heroVideo.playbackRate = 2.5;
      }

      const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
      const contactSubmit = document.getElementById('contact-submit') as HTMLButtonElement | null;
      const contactStatus = document.getElementById('contact-status') as HTMLParagraphElement | null;

      contactForm?.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!contactForm.checkValidity()) {
          contactForm.reportValidity();
          return;
        }

        const formData = new FormData(contactForm);
        const payload = Object.fromEntries(formData.entries());

        if (contactSubmit) {
          contactSubmit.disabled = true;
          contactSubmit.textContent = 'Enviando...';
        }

        if (contactStatus) {
          contactStatus.className = 'text-sm font-semibold text-secondary';
          contactStatus.textContent = 'Estamos enviando tu solicitud.';
        }

        try {
          const response = await fetch('/api/contacto', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(payload),
          });

          const result = await response.json();

          if (!response.ok || !result.ok) {
            console.error('[contacto] Error del servidor', {
              status: response.status,
              requestId: result.requestId,
              message: result.message,
            });
            throw new Error(result.message ?? 'No pudimos enviar la cotización.');
          }

          contactForm.reset();
          window.location.href = '/gracias';
          return;
        } catch (error) {
          if (contactStatus) {
            contactStatus.className = 'text-sm font-semibold text-red-700';
            contactStatus.textContent = error instanceof Error ? error.message : 'No pudimos enviar la cotización.';
          }
        } finally {
          if (contactSubmit) {
            contactSubmit.disabled = false;
            contactSubmit.textContent = 'Cotizar';
          }
        }
      });
    }
  </script>
</Layout>
