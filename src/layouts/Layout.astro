---
import "../styles/global.css";
import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
</head>
<body class="bg-white text-secondary antialiased">

  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
      <div class="flex items-center">
        <a href="#inicio">
          <img src="/images/mafra-logistics.webp" alt="Mafra Logistics" class="h-12 w-auto" />
        </a>
      </div>
      <nav class="hidden md:flex space-x-8 text-sm font-medium">
        <a href="#inicio" class="hover:text-primary transition-colors">Inicio</a>
        <a href="#flota" class="hover:text-primary transition-colors">Nuestra Flota</a>
        <a href="#servicios" class="hover:text-primary transition-colors">Servicios</a>
      </nav>
      <div class="flex items-center gap-3">
        <a href="#cotizar" class="hidden sm:inline-block bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded text-sm font-semibold transition-all shadow-sm">Cotizar Flete</a>
        <button id="mobile-menu-btn" type="button" aria-label="Abrir menú" aria-expanded="false" class="md:hidden p-2 -mr-2 text-secondary">
          <i class="ph ph-list text-2xl"></i>
        </button>
      </div>
    </div>
    <nav id="mobile-menu" class="hidden md:hidden flex-col px-4 pb-4 space-y-1 text-sm font-medium bg-white border-t border-gray-100">
      <a href="#inicio" class="block py-2 hover:text-primary transition-colors">Inicio</a>
      <a href="#flota" class="block py-2 hover:text-primary transition-colors">Nuestra Flota</a>
      <a href="#servicios" class="block py-2 hover:text-primary transition-colors">Servicios</a>
      <a href="#cotizar" class="block mt-2 bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded text-sm font-semibold text-center transition-all shadow-sm">Cotizar Flete</a>
    </nav>
  </header>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (menuBtn && menu) {
      menuBtn.addEventListener('click', () => {
        const isOpen = menu.classList.toggle('flex');
        menu.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
        menuBtn.querySelector('i')?.classList.toggle('ph-list');
        menuBtn.querySelector('i')?.classList.toggle('ph-x');
      });
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menu.classList.add('hidden');
          menu.classList.remove('flex');
          menuBtn.setAttribute('aria-expanded', 'false');
          menuBtn.querySelector('i')?.classList.add('ph-list');
          menuBtn.querySelector('i')?.classList.remove('ph-x');
        });
      });
    }
  </script>

  <main>
    <slot />
  </main>

  <footer class="bg-gray-50 border-t border-gray-100 py-12 text-sm text-text-muted">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <img src="/images/mafra-logistics.webp" alt="Mafra Logistics" class="h-14 w-auto mb-4" loading="lazy" />
        <p>Tu aliado estratégico en transporte logístico B2B que responde cuando otros te quedan mal.</p>
        <p class="mt-4">&copy; 2026 Mafra Logistics. Todos los derechos reservados.</p>
      </div>
      <div>
        <p class="font-bold text-secondary mb-4">Datos de Contacto</p>
        <p class="mb-2"><strong class="text-secondary">Ventas México:</strong> <a href="tel:+528129115812" class="hover:text-primary transition-colors">+52 812-911-5812</a></p>
        <p class="mb-2"><a href="mailto:sales@mafragrp.com" class="hover:text-primary transition-colors">sales@mafragrp.com</a></p>
        <p><strong class="text-secondary">Dirección:</strong> Cordillera del Himalaya 914, San Nicolás de los Garza, Nuevo León, C.P. 66430.</p>
      </div>
      <div>
        <p class="font-bold text-secondary mb-4">Legal</p>
        <!-- Placeholder: enlazar páginas legales cuando existan -->
        <p class="mb-2"><a href="#" class="hover:text-primary transition-colors">Aviso de Privacidad</a></p>
        <p><a href="#" class="hover:text-primary transition-colors">Términos y Condiciones</a></p>
      </div>
    </div>
  </footer>

  <script>
    import { Swiper } from 'swiper';
    import { Navigation, Pagination } from 'swiper/modules';

    document.addEventListener('DOMContentLoaded', () => {
      new Swiper('.flotaSwiper', {
        modules: [Navigation, Pagination],
        slidesPerView: 1,
        spaceBetween: 24,
        pagination: { el: '.swiper-pagination', clickable: true },
        navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
        breakpoints: {
          768: { slidesPerView: 2 },
          1024: { slidesPerView: 3 }
        }
      });
    });
  </script>

  <script is:inline src="https://conversia.com.mx/assets/js/chatbot.js" id="chatbot-js"></script>
  <script is:inline>
    CHATKODEX.init({
      host: window.location.host,
      key: "roHNZFsyBmLw3"
    });
  </script>
</body>
</html>
